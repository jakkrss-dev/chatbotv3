{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/uploads/(.*)", "destination": "http://localhost:8001/uploads/$1" },
    { "source": "/(.*)", "destination": "/frontend/dist/$1" }
  ],
  "functions": {
    "api/index.py": {
      "runtime": "vercel-python@1.1.0"
    }
  }
}
